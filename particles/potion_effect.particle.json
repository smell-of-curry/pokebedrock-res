{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "pokeb:potion_effect",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/particle/sparkle"
			}
		},
		"curves": {
			"variable.size": {
				"type": "bezier_chain",
				"input": "v.particle_age/v.particle_lifetime",
				"nodes": {
					"0.0": {
						"value": 0,
						"slope": 0
					},
					"0.2": {
						"value": 1,
						"slope": 0
					},
					"1.0": {
						"value": 0,
						"slope": -3
					}
				}
			}
		},
		"components": {
			"minecraft:emitter_rate_instant": {
				"num_particles": 8
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 0.5
			},
			"minecraft:emitter_shape_box": {
				"offset": [0, 0, 0],
				"half_dimensions": [0.4, 0.7, 0.4],
				"direction": "outwards"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "math.random(1.0, 2.0)"
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(-45, 45)"
			},
			"minecraft:particle_initial_speed": 0.05,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, 0.8, 0],
				"linear_drag_coefficient": 1.2
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["0.12 * variable.size", "0.12 * variable.size"],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 84,
					"texture_height": 12,
					"flipbook": {
						"base_UV": [0, 0],
						"size_UV": [12, 12],
						"step_UV": [12, 0],
						"frames_per_second": 16,
						"max_frame": 7,
						"stretch_to_lifetime": true
					}
				}
			},
			"minecraft:particle_appearance_lighting": {},
			"minecraft:particle_appearance_tinting": {
				"color": [
					"variable.potion_color.r",
					"variable.potion_color.g",
					"variable.potion_color.b",
					1
				]
			}
		}
	}
}
