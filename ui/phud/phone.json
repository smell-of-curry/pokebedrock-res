{
  "namespace": "phud_phone",
  "main": {
    "type": "panel",
    "controls": [{ "icons@icons": {} }, { "backgrounds@backgrounds": {} }]
  },
  "backgrounds": {
    "type": "panel",
    "controls": [
      { "phone@phone_background": {} },
      { "oak_talk_bg@oak_talk_bg": {} }
    ]
  },
  "icon@abstract_phone_conditional": {
    "texture": "('textures/ui/phud/' + $name)"
  },
  "oak_icon": {
    "type": "image",
    "texture": "('textures/ui/phud/oak_' + $name))",
    "uv_size": [64, 64],
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "view",
        "source_control_name": "elements",
        "source_property_name": "#phone",
        "target_property_name": "#value"
      }
    ]
  },
  "icons": {
    "type": "panel",
    "controls": [
      {
        "ringing@icon": {
          "$condition": "(#value = 'ring')",
          "$name": "ringing",
          "uv": "@phud_phone.anim__ringing",
          "uv_size": [64, 64]
        }
      },
      {
        "standby@icon": {
          "$condition": "(#value = 'standby')",
          "$name": "standby"
        }
      },
      { "oak_talk@oak_talk": {} }
    ],
    "layer": 1
  },
  "phone_background@abstract_phone_conditional": {
    "texture": "textures/ui/phud/box_small",
    "$condition": "((#value = 'ring') or (#value = 'standby')"
  },
  "oak_talk_bg@abstract_phone_conditional": {
    "type": "image",
    "$condition": "((%.4s * #value) = 'loop')",
    "size": ["100%", "100%"],
    "texture": "textures/ui/phud/box_wide",
    "alpha": 0,
    "anims": ["@phud_phone.anim__oak_loop_show__0"]
  },
  "oak_talk@abstract_phone_conditional": {
    "type": "panel",
    "size": ["100%", "100%"],
    "$condition": "((%.4s * #value) = 'loop')",
    "controls": [
      {
        "start@oak_icon": {
          "uv": "@phud_phone.anim__oak_start_flipbook",
          "anims": ["@phud_phone.anim__oak_start_destroy"],
          "$name": "start"
        }
      },
      {
        "loop@oak_icon": {
          "uv": "@phud_phone.anim__oak_loop_flipbook",
          "anims": ["@phud_phone.anim__oak_loop_show__0"],
          "alpha": 0,
          "$name": "loop"
        }
      }
    ]
  },
  "abstract_phone_conditional": {
    "type": "image",
    "size": ["100%", "100%"],
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "view",
        "source_control_name": "elements",
        "source_property_name": "#phone",
        "target_property_name": "#value"
      },
      {
        "binding_name": "#null",
        "binding_type": "view",
        "source_property_name": "$condition",
        "target_property_name": "#visible"
      },
      {
        "binding_name": "#null",
        "binding_type": "view",
        "source_property_name": "$condition",
        "target_property_name": "#enabled"
      }
    ]
  },
  "anim__ringing": {
    "anim_type": "flip_book",
    "initial_uv": [0, 0],
    "frame_count": 11,
    "fps": 11,
    "frame_step": 64
  },
  "anim__oak_start_flipbook": {
    "anim_type": "flip_book",
    "initial_uv": [0, 0],
    "frame_count": 12,
    "fps": 12,
    "frame_step": 64
  },
  "anim__oak_start_destroy": {
    "anim_type": "wait",
    "duration": 0.97,
    "destroy_at_end": "start"
  },
  "anim__oak_loop_flipbook": {
    "anim_type": "flip_book",
    "initial_uv": [0, 0],
    "frame_count": 8,
    "fps": 12,
    "frame_step": 64
  },
  "anim__oak_loop_show__0": {
    "anim_type": "wait",
    "duration": 0.97,
    "next": "@phud_phone.anim__oak_loop_show__1"
  },
  "anim__oak_loop_show__1": {
    "anim_type": "alpha",
    "duration": 0,
    "from": 1,
    "to": 1
  }
}
