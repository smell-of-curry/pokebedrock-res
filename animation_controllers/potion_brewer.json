{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.potion_brewer": {
      "initial_state": "default",
      "states": {
        "default": {
          "animations": ["closed_idle"],
          "transitions": [
            {
              "opening": "query.property('pokeb:potion_brewer_state') == 'opening'"
            },
            {
              "closing": "query.property('pokeb:potion_brewer_state') == 'closing'"
            },
            {
              "opened_idle": "query.property('pokeb:potion_brewer_state') == 'opened'"
            },
            {
              "closed_idle": "query.property('pokeb:potion_brewer_state') == 'closed'"
            }
          ]
        },
        "opening": {
          "animations": ["opening"],
          "transitions": [
            {
              "default": "query.property('pokeb:potion_brewer_state') != 'opening'"
            }
          ]
        },
        "closing": {
          "animations": ["closing"],
          "transitions": [
            {
              "default": "query.property('pokeb:potion_brewer_state') != 'closing'"
            }
          ]
        },
        "opened_idle": {
          "animations": ["opened_idle"],
          "transitions": [
            {
              "default": "query.property('pokeb:potion_brewer_state') != 'opened'"
            }
          ]
        },
        "closed_idle": {
          "animations": ["closed_idle"],
          "transitions": [
            {
              "default": "query.property('pokeb:potion_brewer_state') != 'closed'"
            }
          ]
        }
      }
    }
  }
}
