{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.cooling_station_tank": {
      "initial_state": "default",
      "states": {
        "default": {
          "animations": ["empty"],
          "transitions": [
            {
              "emptying": "query.property('pokeb:cooling_station_tank_state') == 'emptying'"
            },
            {
              "filling": "query.property('pokeb:cooling_station_tank_state') == 'filling'"
            },
            {
              "empty": "query.property('pokeb:cooling_station_tank_state') == 'empty'"
            },
            {
              "full": "query.property('pokeb:cooling_station_tank_state') == 'full'"
            }
          ]
        },
        "emptying": {
          "animations": ["emptying"],
          "transitions": [
            {
              "default": "query.property('pokeb:cooling_station_tank_state') != 'emptying'"
            }
          ]
        },
        "filling": {
          "animations": ["filling"],
          "transitions": [
            {
              "default": "query.property('pokeb:cooling_station_tank_state') != 'filling'"
            }
          ]
        },
        "empty": {
          "animations": ["empty"],
          "transitions": [
            {
              "default": "query.property('pokeb:cooling_station_tank_state') != 'empty'"
            }
          ]
        },
        "full": {
          "animations": ["full"],
          "transitions": [
            {
              "default": "query.property('pokeb:cooling_station_tank_state') != 'full'"
            }
          ]
        }
      }
    }
  }
}
