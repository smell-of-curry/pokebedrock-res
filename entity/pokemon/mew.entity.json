{
	"format_version": "1.18.3",
	"minecraft:client_entity": {
		"description": {
			"identifier": "pokemon:mew",
			"materials": {
				"default": "entity_emissive_alpha",
				"aura": "charged_creeper"
			},
			"textures": {
				"evo_aura": "textures/entity/evolving",
				"default": "textures/entity/pokemon/mew/mew.png",
				"shiny_default": "textures/entity/pokemon/mew/shiny_mew.png",
				"christmas": "textures/entity/pokemon/mew/mew_christmas.png",
				"shadow": "textures/entity/pokemon/mew/mew_shadow.png",
				"shiny_shadow": "textures/entity/pokemon/mew/shiny_mew_shadow.png",
				"princess": "textures/entity/pokemon/mew/mew_princess.png",
				"shiny_princess": "textures/entity/pokemon/mew/shiny_mew_princess.png"
			},
			"scripts": {
				"scale": "q.property('pokeb:scale')",
				"initialize": [
					"v.blink_chance = 0.01;",
					"v.move_threshold = 0.01;"
				],
				"pre_animation": [
					"v.skin_index = query.property('pokeb:skin_index');",
					"v.is_ground_idling = query.is_on_ground && query.modified_move_speed < v.move_threshold;",
					"v.is_air_idling = !query.is_on_ground && !query.is_in_water && !query.is_jumping && query.modified_move_speed < v.move_threshold;",
					"v.is_water_idling = query.is_in_water && !query.is_swimming;",
					"v.is_walking = query.modified_move_speed >= v.move_threshold && query.is_on_ground && !query.is_in_water;",
					"v.is_swimming = query.is_swimming;",
					"v.is_flying = query.modified_move_speed >= v.move_threshold && q.can_fly && !query.is_on_ground && !query.is_in_water && !query.is_jumping;",
					"v.is_sleeping = q.is_sleeping;",
					"v.should_blink = math.random(0.0, 1.0) <= v.blink_chance;"
				],
				"animate": [
					"controller",
					{
						"blink": "v.should_blink"
					}
				]
			},
			"animations": {
				"default_blink": "animation.mew.blink",
				"default_ground_idle": "animation.mew.ground_idle",
				"default_air_idle": "animation.mew.air_idle",
				"default_water_idle": "animation.mew.water_idle",
				"default_walking": "animation.mew.walking",
				"default_flying": "animation.mew.flying",
				"default_swimming": "animation.mew.swimming",
				"default_sleeping": "animation.mew.sleeping",
				"default_attack": "animation.mew.attack",
				"christmas_flying": "animation.mew_christmas.flying",
				"christmas_air_idle": "animation.mew_christmas.air_idle",
				"christmas_swimming": "animation.mew_christmas.swimming",
				"christmas_water_idle": "animation.mew_christmas.water_idle",
				"christmas_walking": "animation.mew_christmas.walking",
				"christmas_ground_idle": "animation.mew_christmas.ground_idle",
				"christmas_sleeping": "animation.mew_christmas.sleeping",
				"christmas_blink": "animation.mew_christmas.blink",
				"christmas_attack": "animation.mew_christmas.attack",
				"christmas_faint": "animation.mew_christmas.faint",
				"shadow_flying": "animation.mew_shadow.flying",
				"shadow_air_idle": "animation.mew_shadow.air_idle",
				"shadow_swimming": "animation.mew_shadow.swimming",
				"shadow_water_idle": "animation.mew_shadow.water_idle",
				"shadow_walking": "animation.mew_shadow.walking",
				"shadow_ground_idle": "animation.mew_shadow.ground_idle",
				"shadow_sleeping": "animation.mew_shadow.sleeping",
				"shadow_blink": "animation.mew_shadow.blink",
				"shadow_attack": "animation.mew_shadow.attack",
				"shadow_faint": "animation.mew_shadow.faint",
				"princess_flying": "animation.mew_princess.flying",
				"princess_air_idle": "animation.mew_princess.air_idle",
				"princess_swimming": "animation.mew_princess.swimming",
				"princess_water_idle": "animation.mew_princess.water_idle",
				"princess_walking": "animation.mew_princess.walking",
				"princess_ground_idle": "animation.mew_princess.ground_idle",
				"princess_sleeping": "animation.mew_princess.sleeping",
				"princess_blink": "animation.mew_princess.blink",
				"princess_attack": "animation.mew_princess.attack",
				"princess_faint": "animation.mew_princess.faint",
				"look_at_target": "animation.pokemon.look_at_target",
				"attack": "controller.animation.pokemon.mew_attack",
				"blink": "controller.animation.pokemon.mew_blink",
				"controller": "controller.animation.pokemon.mew"
			},
			"render_controllers": [
				{
					"controller.render.pokemon:mew": "query.variant==0"
				},
				{
					"controller.render.pokemon:mew.evolve": "query.variant==1"
				}
			],
			"spawn_egg": {
				"texture": "mew",
				"texture_index": 0
			},
			"geometry": {
				"default": "geometry.mew",
				"christmas": "geometry.mew_christmas",
				"shadow": "geometry.mew_shadow",
				"princess": "geometry.mew_princess"
			}
		}
	}
}
