{
	"format_version": "1.18.3",
	"minecraft:client_entity": {
		"description": {
			"identifier": "pokemon:arceusrock",
			"materials": {
				"default": "entity_emissive_alpha",
				"aura": "charged_creeper"
			},
			"textures": {
				"evo_aura": "textures/entity/evolving",
				"default": "textures/entity/pokemon/arceusrock/arceusrock.png",
				"shiny_default": "textures/entity/pokemon/arceusrock/shiny_arceusrock.png",
				"omega": "textures/entity/pokemon/arceusrock/arceusrock_omega.png",
				"shiny_omega": "textures/entity/pokemon/arceusrock/shiny_arceusrock_omega.png"
			},
			"scripts": {
				"scale": "q.property('pokeb:scale')",
				"initialize": [
					"v.blink_chance = 0.01;",
					"v.move_threshold = 0.01;"
				],
				"pre_animation": [
					"v.skin_index = query.property('pokeb:skin_index');",
					"v.is_ground_idling = query.is_on_ground && query.modified_move_speed < v.move_threshold;",
					"v.is_air_idling = !query.is_on_ground && !query.is_in_water && !query.is_jumping && query.modified_move_speed < v.move_threshold;",
					"v.is_water_idling = query.is_in_water && !query.is_swimming;",
					"v.is_walking = query.modified_move_speed >= v.move_threshold && query.is_on_ground && !query.is_in_water;",
					"v.is_swimming = query.is_swimming;",
					"v.is_flying = query.modified_move_speed >= v.move_threshold && q.can_fly && !query.is_on_ground && !query.is_in_water && !query.is_jumping;",
					"v.is_sleeping = q.is_sleeping;",
					"v.should_blink = math.random(0.0, 1.0) <= v.blink_chance;"
				],
				"animate": [
					"controller",
					{
						"blink": "v.should_blink"
					}
				]
			},
			"animations": {
				"default_blink": "animation.arceusrock.blink",
				"default_ground_idle": "animation.arceusrock.ground_idle",
				"default_air_idle": "animation.arceusrock.ground_idle",
				"default_water_idle": "animation.arceusrock.water_idle",
				"default_walking": "animation.arceusrock.walking",
				"default_flying": "animation.arceusrock.ground_idle",
				"default_swimming": "animation.arceusrock.swimming",
				"default_sleeping": "animation.arceusrock.sleeping",
				"default_attack": "animation.arceusrock.attack",
				"omega_flying": "animation.arceusrock_omega.flying",
				"omega_air_idle": "animation.arceusrock_omega.air_idle",
				"omega_swimming": "animation.arceusrock_omega.swimming",
				"omega_water_idle": "animation.arceusrock_omega.water_idle",
				"omega_walking": "animation.arceusrock_omega.walking",
				"omega_ground_idle": "animation.arceusrock_omega.ground_idle",
				"omega_sleeping": "animation.arceusrock_omega.sleeping",
				"omega_blink": "animation.arceusrock_omega.blink",
				"omega_attack": "animation.arceusrock_omega.attack",
				"omega_faint": "animation.arceusrock_omega.faint",
				"look_at_target": "animation.pokemon.look_at_target",
				"attack": "controller.animation.pokemon.arceusrock_attack",
				"blink": "controller.animation.pokemon.arceusrock_blink",
				"controller": "controller.animation.pokemon.arceusrock"
			},
			"render_controllers": [
				{
					"controller.render.pokemon:arceusrock": "query.variant==0"
				},
				{
					"controller.render.pokemon:arceusrock.evolve": "query.variant==1"
				}
			],
			"spawn_egg": {
				"texture": "arceusrock",
				"texture_index": 0
			},
			"geometry": {
				"default": "geometry.arceusrock",
				"omega": "geometry.arceusrock_omega"
			}
		}
	}
}
