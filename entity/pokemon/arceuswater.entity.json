{
	"format_version": "1.18.3",
	"minecraft:client_entity": {
		"description": {
			"identifier": "pokemon:arceuswater",
			"materials": {
				"default": "entity_emissive_alpha",
				"aura": "charged_creeper"
			},
			"textures": {
				"evo_aura": "textures/entity/evolving",
				"default": "textures/entity/pokemon/arceuswater/arceuswater.png",
				"shiny_default": "textures/entity/pokemon/arceuswater/shiny_arceuswater.png",
				"omega": "textures/entity/pokemon/arceuswater/arceuswater_omega.png",
				"shiny_omega": "textures/entity/pokemon/arceuswater/shiny_arceuswater_omega.png"
			},
			"scripts": {
				"scale": "q.property('pokeb:scale')",
				"initialize": [
					"v.blink_chance = 0.01;",
					"v.move_threshold = 0.01;"
				],
				"pre_animation": [
					"v.skin_index = query.property('pokeb:skin_index');",
					"v.is_ground_idling = query.is_on_ground && query.modified_move_speed < v.move_threshold;",
					"v.is_air_idling = !query.is_on_ground && !query.is_in_water && !query.is_jumping && query.modified_move_speed < v.move_threshold;",
					"v.is_water_idling = query.is_in_water && !query.is_swimming;",
					"v.is_walking = query.modified_move_speed >= v.move_threshold && query.is_on_ground && !query.is_in_water;",
					"v.is_swimming = query.is_swimming;",
					"v.is_flying = query.modified_move_speed >= v.move_threshold && q.can_fly && !query.is_on_ground && !query.is_in_water && !query.is_jumping;",
					"v.is_sleeping = q.is_sleeping;",
					"v.should_blink = math.random(0.0, 1.0) <= v.blink_chance;"
				],
				"animate": [
					"controller",
					{
						"blink": "v.should_blink"
					}
				]
			},
			"animations": {
				"default_blink": "animation.arceuswater.blink",
				"default_ground_idle": "animation.arceuswater.ground_idle",
				"default_air_idle": "animation.arceuswater.ground_idle",
				"default_water_idle": "animation.arceuswater.water_idle",
				"default_walking": "animation.arceuswater.walking",
				"default_flying": "animation.arceuswater.ground_idle",
				"default_swimming": "animation.arceuswater.swimming",
				"default_sleeping": "animation.arceuswater.sleeping",
				"default_attack": "animation.arceuswater.attack",
				"omega_flying": "animation.arceuswater_omega.flying",
				"omega_air_idle": "animation.arceuswater_omega.air_idle",
				"omega_swimming": "animation.arceuswater_omega.swimming",
				"omega_water_idle": "animation.arceuswater_omega.water_idle",
				"omega_walking": "animation.arceuswater_omega.walking",
				"omega_ground_idle": "animation.arceuswater_omega.ground_idle",
				"omega_sleeping": "animation.arceuswater_omega.sleeping",
				"omega_blink": "animation.arceuswater_omega.blink",
				"omega_attack": "animation.arceuswater_omega.attack",
				"omega_faint": "animation.arceuswater_omega.faint",
				"look_at_target": "animation.pokemon.look_at_target",
				"attack": "controller.animation.pokemon.arceuswater_attack",
				"blink": "controller.animation.pokemon.arceuswater_blink",
				"controller": "controller.animation.pokemon.arceuswater"
			},
			"render_controllers": [
				{
					"controller.render.pokemon:arceuswater": "query.variant==0"
				},
				{
					"controller.render.pokemon:arceuswater.evolve": "query.variant==1"
				}
			],
			"spawn_egg": {
				"texture": "arceuswater",
				"texture_index": 0
			},
			"geometry": {
				"default": "geometry.arceuswater",
				"omega": "geometry.arceuswater_omega"
			}
		}
	}
}
