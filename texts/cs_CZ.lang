showdown.moves.hiddenpowerdark.name=Skrytá temná síla
showdown.moves.hiddenpowerdragon.name=Drak skryté síly
showdown.moves.hiddenpowerelectric.name=Skrytá elektrická energie
showdown.moves.hiddenpowerfighting.name=Skrytý boj o moc
showdown.moves.hiddenpowerfire.name=Skrytá síla
