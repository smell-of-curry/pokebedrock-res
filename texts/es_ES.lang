showdown.abilities.hospitality.heal=¡%s se bebió todo el matcha que %s hizo!
showdown.abilities.hugepower.name=Potencia
showdown.abilities.hugepower.shortDesc=El ataque de este Pokémon se duplica.
showdown.abilities.hungerswitch.name=Mutapetito
showdown.abilities.hungerswitch.desc=Si este Pokémon es un Morpeko, cambia de forma entre el modo Full Belly y el modo Hangry al final de cada turno.
showdown.abilities.hungerswitch.shortDesc=Si es Morpeko, cambia entre Full Belly y Hangry Mode al final de cada turno.
showdown.abilities.hustle.name=Entusiasmo
showdown.abilities.hustle.desc=El ataque de este Pokémon se multiplica por 1,5 y la precisión de sus ataques físicos se multiplica por 0,8.
showdown.abilities.hustle.shortDesc=El ataque de este Pokémon es 1,5x y la precisión de sus ataques físicos es 0,8x.
showdown.abilities.hydration.name=Hidratación
