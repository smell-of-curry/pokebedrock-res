showdown.abilities.watercompaction.name=Water Compaction
showdown.abilities.watercompaction.shortDesc=A defesa deste Pokémon aumenta 2 estágios após ser danificado por um movimento do tipo Água.
showdown.abilities.waterveil.name=Water Veil
