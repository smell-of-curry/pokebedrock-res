showdown.moves.lastresort.name=Last Resort
showdown.moves.lastresort.desc=Este movimento falha a menos que o usuário conheça este movimento e pelo menos um outro movimento, e tenha usado todos os outros movimentos que conhece pelo menos uma vez desde que se tornou ativo ou transformado.
showdown.moves.lastresort.shortDesc=Falha a menos que cada movimento conhecido tenha sido usado.
