showdown.abilities.armortail.shortDesc=Este Pokémon e seus aliados estão protegidos de movimentos prioritários adversários.
showdown.abilities.aromaveil.name=Aroma Veil
showdown.abilities.aromaveil.desc=Este Pokémon e seus aliados não podem ser afetados por Attract, Disable, Encore, Heal Block, Taunt ou Torment.
showdown.abilities.aromaveil.shortDesc=Protege usuários/aliados de Atrair, Desabilitar, Encore, Bloqueio de Cura, Provocação e Tormento.
showdown.abilities.aromaveil.block=%s está protegido por um véu aromático!
showdown.abilities.asone.name=As One
showdown.abilities.asone.shortDesc=Consulte 'As One (Glastrier)' e 'As One (Spectrier)'.
showdown.abilities.asone.start=%s tem duas habilidades!
