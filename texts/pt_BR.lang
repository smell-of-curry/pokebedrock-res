showdown.abilities.immunity.shortDesc=Este Pokémon não pode ser envenenado. Ganhar esta habilidade enquanto estiver envenenado a cura.
showdown.abilities.imposter.name=Imposter
showdown.abilities.imposter.desc=Ao fazer switch-in, este Pokémon se transforma no Pokémon oponente que o enfrenta. Se não houver nenhum Pokémon nessa posição, este Pokémon não se transforma.
showdown.abilities.imposter.shortDesc=Ao fazer switch-in, este Pokémon se transforma no Pokémon oponente que o enfrenta.
showdown.abilities.infiltrator.name=Infiltrator
showdown.abilities.infiltrator.desc=Os movimentos deste Pokémon ignoram substitutos e Reflect, Light Screen, Safeguard, Mist e Aurora Veil do lado oposto.
showdown.abilities.infiltrator.shortDesc=Movimentos ignoram substitutos e Reflect/Light Screen/Safeguard/Mist/Aurora Veil do inimigo.
showdown.abilities.innardsout.name=Innards Out
showdown.abilities.innardsout.desc=Se este Pokémon for nocauteado com um movimento, o usuário desse movimento perde HP igual à quantidade de dano infligido a este Pokémon.
