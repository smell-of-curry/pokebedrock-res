showdown.abilities.download.name=Download
showdown.abilities.download.desc=Na switch-in, o Attack ou Special Attack deste Pokémon é aumentado em 1 estágio com base nas estatísticas defensivas combinadas mais fracas de todos os Pokémon adversários. O ataque aumenta se a defesa for menor, e o ataque especial aumenta se a defesa especial for igual ou menor.
showdown.abilities.download.shortDesc=Na switch-in, Attack ou Sp. O Atk aumenta 1 estágio com base na Defesa mais fraca do inimigo.
showdown.abilities.dragonsmaw.name=Dragon's Maw
showdown.abilities.dragonsmaw.shortDesc=A estatística ofensiva deste Pokémon é multiplicada por 1,5 ao usar um ataque do tipo Dragão.
showdown.abilities.drizzle.name=Drizzle
