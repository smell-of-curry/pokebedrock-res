showdown.abilities.magnetpull.name=Magnet Pull
showdown.abilities.magnetpull.desc=Impede que Pokémon do tipo Steel adversários optem por trocar, a menos que estejam segurando um Shed Shell ou sejam do tipo Ghost.
showdown.abilities.magnetpull.shortDesc=Impede que Pokémon do tipo Steel adversários optem por trocar.
showdown.abilities.marvelscale.name=Marvel Scale
showdown.abilities.marvelscale.shortDesc=Se este Pokémon tiver uma condição de status não volátil, sua Defesa será multiplicada por 1,5.
showdown.abilities.megalauncher.name=Mega Launcher
showdown.abilities.megalauncher.desc=Os movimentos de pulso deste Pokémon têm seu poder multiplicado por 1,5. Heal Pulse restaura 3/4 do HP máximo do alvo, arredondado pela metade para baixo.
showdown.abilities.megalauncher.shortDesc=Os movimentos de pulso deste Pokémon têm potência de 1,5x. Heal Pulse cura 3/4 do HP máximo do alvo.
showdown.abilities.merciless.name=Merciless
